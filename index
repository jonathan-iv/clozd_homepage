    var ofStat = document.getElementById('ofStat');
    var ofUnit = document.getElementById('ofUnit');
    var ofDesc = document.getElementById('ofDesc');
    var ofMedia = document.getElementById('ofMedia');
    var ofMark = document.getElementById('ofMark');
    var ofName = document.getElementById('ofName');
    var ofCo = document.getElementById('ofCo');
    var ofLink = featured && featured.querySelector('.of-logo .link');
    var buttons = document.querySelectorAll('.di-bento .os');

    function loadStory(key){
      var s = stories[key];
      if(!s) return;
      ofTag.textContent = s.tag;
      ofStat.textContent = s.stat;
      ofUnit.textContent = s.unit;
      ofDesc.textContent = s.desc;
      ofMedia.innerHTML = s.media;
      ofMark.textContent = s.mark;
      ofMark.style.background = s.markGrad;
      ofName.textContent = s.name;
      ofCo.textContent = s.co;
      if(ofLink){ ofLink.innerHTML = s.linkText + ' <span>&rarr;</span>'; }
      for(var i=0;i<buttons.length;i++){
        var b = buttons[i];
        var active = b.getAttribute('data-story') === key;
        b.classList.toggle('os-active', active);
        b.setAttribute('aria-selected', active ? 'true' : 'false');
      }
    }

    for(var i=0;i<buttons.length;i++){
      (function(btn){
        btn.addEventListener('click', function(){ loadStory(btn.getAttribute('data-story')); });
      })(buttons[i]);
    }
  })();

  /* ---------- Persona video reel lightbox ---------- */
  (function(){
    var box = document.getElementById('vbox');
    if(!box) return;
    var boxVideo = document.getElementById('vboxVideo');
    var boxQuote = document.getElementById('vboxQuote');
    var boxName  = document.getElementById('vboxName');
    var boxRole  = document.getElementById('vboxRole');
    var boxLogo  = document.getElementById('vboxLogo');
    var boxClose = document.getElementById('vboxClose');

    function open(card){
      var role = card.getAttribute('data-vclip') || '';
      var logoClass = card.getAttribute('data-logo-class') || '';
      var logoText  = card.getAttribute('data-logo-text') || '';
      // Match poster look to the clicked card's class for color consistency
      boxVideo.className = 'vbox-video ' + role;
      boxQuote.textContent = card.getAttribute('data-quote') || '';
      boxName.textContent = card.getAttribute('data-name') || '';
      boxRole.textContent = card.getAttribute('data-role') || '';
      boxLogo.className = 'vblogo ' + logoClass;
      boxLogo.textContent = logoText;
      box.classList.add('open');
      box.setAttribute('aria-hidden','false');
      document.body.style.overflow = 'hidden';
    }
    function close(){
      box.classList.remove('open');
      box.setAttribute('aria-hidden','true');
      document.body.style.overflow = '';
    }
    var clips = document.querySelectorAll('.vclip');
    for(var i=0;i<clips.length;i++){
      (function(c){ c.addEventListener('click', function(){ open(c); }); })(clips[i]);
    }
    boxClose.addEventListener('click', close);
    box.addEventListener('click', function(e){ if(e.target === box) close(); });
    document.addEventListener('keydown', function(e){ if(e.key === 'Escape') close(); });
  })();

  /* ---------- Customer journey tab switcher ---------- */
  (function(){
    var tabs = document.querySelectorAll('.journey-tabs .jt');
    var panels = document.querySelectorAll('.journey-panels .jp');
    function show(key){
      for(var i=0;i<tabs.length;i++){
        var t = tabs[i];
        var on = t.getAttribute('data-moment') === key;
        t.classList.toggle('active', on);
        t.setAttribute('aria-selected', on ? 'true' : 'false');
      }
      for(var j=0;j<panels.length;j++){
        var p = panels[j];
        p.classList.toggle('active', p.getAttribute('data-panel') === key);
      }
    }
    for(var k=0;k<tabs.length;k++){
      (function(btn){
        btn.addEventListener('click', function(){ show(btn.getAttribute('data-moment')); });
      })(tabs[k]);
    }
  })();
</script>

