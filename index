<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Clozd — The feedback engine for revenue teams</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root{
    --royal:#274FDB;
    --blue:#14A6F8;
    --teal:#09D4C8;
    --ink:#000000;
    --body:#565F66;
    --muted:#8A9198;
    --page:#F7F8F9;
    --white:#FFFFFF;
    --line:#ECEEF1;
    /* semantic */
    --wl:#14A6F8;     /* Win-Loss — Blue */
    --ret:#F8C220;    /* but this is data-viz; use Yellow for Retention per spec */
    --retention:#F4B81A; /* Retention — Yellow */
    --impl:#00C371;   /* Implementation — Green  (marketing note: these per brand spec) */
    --cx:#865CFF;     /* CX — Purple */
    --shadow: 0 10px 25px rgba(0,0,0,.12);
    --shadow-sm: 0 6px 16px rgba(0,0,0,.08);
    --grad: linear-gradient(120deg,#274FDB 0%, #14A6F8 50%, #09D4C8 100%);
  }
  *{box-sizing:border-box;margin:0;padding:0}
  html,body{background:var(--white);color:var(--body);font-family:'Inter',system-ui,sans-serif;font-weight:400;line-height:1.5;-webkit-font-smoothing:antialiased}
  a{color:inherit;text-decoration:none}
  img{display:block;max-width:100%}

  /* ---------- Layout helpers ---------- */
  .wrap{max-width:1240px;margin:0 auto;padding:0 32px}
  .eyebrow{font-weight:600;letter-spacing:.12em;text-transform:uppercase;font-size:13px;color:var(--royal)}
  .eyebrow.on-dark{color:rgba(255,255,255,.9)}
  h1,h2,h3,h4{color:var(--ink);font-weight:600;line-height:1.08;letter-spacing:-.01em}
  h1{font-size:68px;line-height:1.04;letter-spacing:-.02em}
  h2{font-size:44px;line-height:1.08}
  h3{font-size:24px;line-height:1.2}
  h4{font-size:18px;line-height:1.25}
  .light{font-weight:300}
  p{font-size:17px;line-height:1.55;color:var(--body)}
  .lede{font-size:19px;line-height:1.55;color:var(--body)}

  /* ---------- Buttons (pills, never rectangles) ---------- */
  .btn{display:inline-flex;align-items:center;gap:8px;padding:14px 22px;border-radius:999px;font-weight:600;font-size:15px;transition:transform .15s ease, box-shadow .15s ease;white-space:nowrap}
  .btn-primary{background:var(--royal);color:#fff;box-shadow:0 8px 20px rgba(39,79,219,.35)}
  .btn-primary:hover{transform:translateY(-1px);box-shadow:0 12px 28px rgba(39,79,219,.45)}
  .btn-ghost{background:rgba(255,255,255,.14);color:#fff;backdrop-filter: blur(6px)}
  .btn-ghost:hover{background:rgba(255,255,255,.24)}
  .btn-light{background:#fff;color:var(--royal);box-shadow:var(--shadow-sm)}
  .btn-light:hover{transform:translateY(-1px)}
  .btn-link{color:var(--royal);font-weight:600;font-size:15px;display:inline-flex;align-items:center;gap:6px}
  .btn-link:hover{color:var(--blue)}

  /* ---------- Nav ---------- */
  .nav{position:sticky;top:0;z-index:50;background:rgba(255,255,255,.85);backdrop-filter:saturate(180%) blur(14px)}
  .nav-inner{display:flex;align-items:center;justify-content:space-between;padding:18px 0}
  .nav-logo img{height:26px}
  .nav-links{display:flex;align-items:center;gap:28px}
  .nav-links a{font-weight:500;font-size:15px;color:#2a323a}
  .nav-links a:hover{color:var(--royal)}
  .nav-cta{display:flex;align-items:center;gap:14px}
  .nav-cta .btn{padding:10px 18px;font-size:14px}
  .nav-sign{color:#2a323a;font-weight:500;font-size:15px}

  /* ---------- Hero (matches Figma: centered, minimal, clean gradient) ---------- */
  .hero{position:relative;overflow:hidden;color:#fff;padding:120px 0 140px;isolation:isolate;text-align:center;
    background:
      radial-gradient(ellipse at 80% 10%, rgba(9,212,200,.55), transparent 55%),
      radial-gradient(ellipse at 15% 100%, rgba(20,166,248,.55), transparent 55%),
      radial-gradient(ellipse at 50% 60%, rgba(9,212,200,.25), transparent 60%),
      linear-gradient(135deg,#1F3FB8 0%, #274FDB 40%, #14A6F8 100%);
  }
  .hero-inner{max-width:1080px;margin:0 auto}
  .hero h1{color:#fff;font-size:60px;line-height:1.08;letter-spacing:-.02em;font-weight:600;white-space:nowrap}
  @media (max-width:1100px){ .hero h1{white-space:normal;font-size:44px} }
  .hero .lede{color:rgba(255,255,255,.92);font-size:19px;line-height:1.55;max-width:720px;margin:24px auto 0}
  .hero-eyebrow{display:inline-flex;align-items:center;gap:10px;background:rgba(255,255,255,.14);padding:8px 16px;border-radius:999px;font-size:13px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:#fff;margin-bottom:28px}
  .hero-eyebrow .dot{width:7px;height:7px;border-radius:999px;background:var(--teal);box-shadow:0 0 0 4px rgba(9,212,200,.25)}
  .hero-ctas{display:flex;justify-content:center;gap:14px;margin-top:36px;flex-wrap:wrap}
  .hero-try{display:inline-flex;align-items:center;gap:10px}
  .hero-try .spark-ai{color:#09D4C8;font-size:14px;line-height:1}
  .hero-try .beta-pill{display:inline-flex;align-items:center;height:20px;padding:0 8px;border-radius:999px;background:linear-gradient(135deg,#09D4C8,#14A6F8);color:#0B1220;font-size:10px;font-weight:800;letter-spacing:.12em;text-transform:uppercase;margin-left:2px;box-shadow:0 2px 6px rgba(9,212,200,.35)}

  /* ---------- Logo row ---------- */
  .logos{padding:48px 0;background:var(--white);border-bottom:1px solid var(--line)}
  .logos .hint{text-align:center;color:var(--muted);font-size:13px;letter-spacing:.14em;text-transform:uppercase;font-weight:600;margin-bottom:28px}
  .logos-grid{display:grid;grid-template-columns:repeat(6,1fr);gap:40px;align-items:center;justify-items:center}
  .fakelogo{font-weight:700;color:#9aa2aa;font-size:20px;letter-spacing:-.02em;font-family:'Inter',sans-serif}

  /* ---------- Generic section ---------- */
  .section{padding:120px 0}
  .section-head{max-width:1200px;margin-bottom:64px}
  .section-head .eyebrow{margin-bottom:16px;display:inline-block}
  .section-head h2{margin-bottom:18px;max-width:920px}
  .section-head .lede{max-width:1180px}

  /* ---------- Decision Intelligence: value + outcomes bento ---------- */
  .di{position:relative;overflow:hidden;background:#fff}
  .di::before{
    content:"";position:absolute;inset:0;z-index:0;pointer-events:none;
    background:
      radial-gradient(ellipse at 85% 0%, rgba(20,166,248,.16), transparent 55%),
      radial-gradient(ellipse at 0% 40%, rgba(9,212,200,.12), transparent 55%),
      radial-gradient(ellipse at 95% 70%, rgba(39,79,219,.14), transparent 55%);
  }
  .di .wrap{position:relative;z-index:1}
  .di-head{max-width:1200px}
  .di-head h2{font-size:52px;line-height:1.06;letter-spacing:-.015em;max-width:960px}
  .di-head .di-emph{color:var(--royal);font-style:italic;font-weight:600}
  .di-head .di-emph::before,.di-head .di-emph::after{color:var(--teal);font-style:normal;font-weight:600}
  .di-head .lede{font-size:20px;line-height:1.55;margin-top:22px;max-width:1180px}
  .di-head .lede strong{color:var(--ink);font-weight:600}

  .di-outcomes-label{display:inline-flex;align-items:center;gap:14px;margin-top:64px;margin-bottom:20px;font-size:13px;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:var(--royal)}
  .di-outcomes-label .dash{display:inline-block;width:40px;height:2px;background:linear-gradient(90deg,var(--teal),var(--royal));border-radius:999px}

  .di-bento{display:grid;grid-template-columns:1.55fr 1fr;gap:22px;align-items:stretch;min-height:540px}

  /* Featured outcome card */
  .of{position:relative;overflow:hidden;border-radius:24px;padding:44px;display:flex;flex-direction:column;justify-content:space-between;box-shadow:var(--shadow-sm);transition:background .3s ease}
  .of::before{content:"";position:absolute;top:-80px;right:-80px;width:340px;height:340px;border-radius:999px;background:radial-gradient(circle, rgba(9,212,200,.32), transparent 65%);pointer-events:none}
  .of::after{content:"";position:absolute;bottom:-100px;left:-100px;width:340px;height:340px;border-radius:999px;background:radial-gradient(circle, rgba(39,79,219,.18), transparent 65%);pointer-events:none}
  .of>*{position:relative;z-index:1}
  .of-tag{display:inline-flex;align-items:center;gap:10px;padding:8px 14px;border-radius:999px;background:rgba(9,212,200,.22);color:#0A7A72;font-weight:600;font-size:12px;letter-spacing:.1em;text-transform:uppercase;align-self:flex-start}
  .of-middle{display:grid;grid-template-columns:1fr 1fr;gap:28px;align-items:end;margin-top:24px}
  .of-num{font-size:104px;font-weight:600;color:var(--ink);letter-spacing:-.05em;line-height:.95}
  .of-num .unit{font-size:60px;color:var(--royal);margin-left:4px}
  .of-desc{font-size:16px;color:var(--body);margin-top:14px;line-height:1.45;max-width:380px}

  /* Media slot: video (square) or custom visual artifact */
  .of-media{min-height:280px;display:flex;align-items:center;justify-content:center;width:100%}
  .of-media .video-wrap{position:relative;width:100%;max-width:300px;aspect-ratio:1/1;border-radius:18px;overflow:hidden;box-shadow:0 18px 40px rgba(15,35,80,.28);background:#0B1220}
  .of-media .video-wrap iframe{position:absolute;inset:0;width:100%;height:100%;border:0}

  /* Shared insight-card wrapper for the three non-video visuals */
  .viz{width:100%;max-width:340px;background:linear-gradient(180deg,#F7FAFF 0%,#ECF3FE 100%);border-radius:18px;padding:20px 22px;box-shadow:0 12px 28px rgba(20,40,90,.08);display:flex;flex-direction:column;gap:14px;position:relative;overflow:hidden}
  .viz::after{content:"";position:absolute;right:-30px;top:-30px;width:120px;height:120px;border-radius:999px;background:radial-gradient(circle,rgba(9,212,200,.18),transparent 70%);pointer-events:none}
  .viz-head{font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--royal);display:flex;align-items:center;gap:8px;position:relative;z-index:1}
  .viz-head .dot{width:6px;height:6px;border-radius:999px;background:linear-gradient(135deg,#09D4C8,#14A6F8)}
  .viz>*{position:relative;z-index:1}

  /* Zoovu — conversion funnel */
  .viz-funnel .stages{display:flex;flex-direction:column;gap:8px}
  .viz-funnel .stage{display:flex;align-items:center;justify-content:space-between;padding:10px 16px;border-radius:999px;font-weight:700;font-size:13px;letter-spacing:-.01em;transition:all .2s}
  .viz-funnel .stage.s1{width:100%;background:rgba(39,79,219,.1);color:var(--royal)}
  .viz-funnel .stage.s2{width:78%;background:rgba(39,79,219,.16);color:var(--royal)}
  .viz-funnel .stage.s3{width:56%;background:rgba(20,166,248,.22);color:#0A66A8}
  .viz-funnel .stage.s4{width:40%;background:linear-gradient(90deg,#14A6F8 0%,#09D4C8 100%);color:#fff;box-shadow:0 8px 18px rgba(9,212,200,.35)}
  .viz-funnel .lift{align-self:flex-start;display:inline-flex;align-items:center;gap:6px;padding:6px 12px;border-radius:999px;background:rgba(9,212,200,.22);color:#0A7A72;font-size:11px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;margin-top:4px}
  .viz-funnel .lift .arrow{font-size:10px}

  /* Optro — ranked win drivers */
  .viz-drivers .rows{display:flex;flex-direction:column;gap:11px}
  .viz-drivers .row{display:grid;grid-template-columns:92px 1fr 34px;align-items:center;gap:10px;font-size:12px;color:var(--body)}
  .viz-drivers .t{font-weight:600;color:var(--ink);font-size:12.5px}
  .viz-drivers .track{height:8px;border-radius:999px;background:rgba(39,79,219,.08);overflow:hidden}
  .viz-drivers .fill{height:100%;border-radius:999px;background:linear-gradient(90deg,#14A6F8 0%,#09D4C8 100%)}
  .viz-drivers .row.dim .fill{background:linear-gradient(90deg,#B8C8E8 0%,#8FA3CC 100%)}
  .viz-drivers .v{text-align:right;font-weight:700;color:var(--ink);font-size:12px}

  /* Clearbit — retention trend */
  .viz-trend{padding-bottom:14px}
  .viz-trend svg{width:100%;height:auto;display:block;margin-top:4px}
  .viz-trend .trend-foot{display:flex;justify-content:space-between;align-items:center;font-size:10.5px;color:var(--body);font-weight:700;letter-spacing:.1em;text-transform:uppercase;margin-top:4px}
  .viz-trend .trend-foot .delta{color:#0A7A72;background:rgba(9,212,200,.22);padding:3px 8px;border-radius:999px;letter-spacing:.06em}

  .of-logo{display:flex;align-items:center;gap:16px;padding-top:28px;margin-top:28px;border-top:1px solid rgba(39,79,219,.16)}
  .of-logo .mark{width:52px;height:52px;border-radius:14px;background:linear-gradient(135deg,#09D4C8,#14A6F8);display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;font-size:22px;box-shadow:0 8px 18px rgba(9,212,200,.3);transition:background .3s ease}
  .of-logo .meta{flex:1}
  .of-logo .name{font-size:22px;font-weight:700;color:var(--ink);letter-spacing:-.02em;line-height:1.1}
  .of-logo .co{font-size:13px;color:var(--body);margin-top:3px}
  .of-logo .link{font-weight:600;color:var(--royal);font-size:14px;display:inline-flex;align-items:center;gap:6px;white-space:nowrap}

  /* Story nav (4 clickable cards) */
  .of-stack{display:flex;flex-direction:column;gap:14px}
  .os{position:relative;background:#fff;border:none;border-radius:18px;padding:20px 22px;box-shadow:var(--shadow-sm);flex:1;display:flex;flex-direction:column;justify-content:center;overflow:hidden;min-height:0;cursor:pointer;text-align:left;font-family:inherit;transition:transform .15s ease, box-shadow .15s ease, background .2s ease;color:inherit}
  .os:hover{transform:translateY(-2px);box-shadow:0 12px 26px rgba(0,0,0,.09)}
  .os::before{content:"";position:absolute;left:0;top:22px;bottom:22px;width:4px;border-radius:999px;opacity:.45;transition:opacity .2s ease, width .2s ease}
  .os[data-story="zoovu"]::before{background:linear-gradient(180deg,#09D4C8,#14A6F8)}
  .os[data-story="optro"]::before{background:linear-gradient(180deg,#14A6F8,#274FDB)}
  .os[data-story="stackadapt"]::before{background:linear-gradient(180deg,#274FDB,#09D4C8)}
  .os[data-story="clearbit"]::before{background:linear-gradient(180deg,#1A2FA0,#274FDB)}
  .os::after{content:"";position:absolute;right:-40px;top:-40px;width:130px;height:130px;border-radius:999px;background:radial-gradient(circle, rgba(20,166,248,.06), transparent 65%);pointer-events:none}
  .os .os-inner{padding-left:16px;display:flex;flex-direction:column;gap:4px}
  .os .os-row{display:flex;align-items:baseline;justify-content:space-between;gap:14px;margin-top:4px}
  .os .label{font-size:12px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--body)}
  .os .num{font-size:40px;font-weight:600;color:var(--ink);letter-spacing:-.03em;line-height:1}
  .os .cust{font-weight:700;color:var(--ink);font-size:15px;letter-spacing:-.01em;display:inline-flex;align-items:center;gap:8px}
  .os .cust .dot{width:14px;height:14px;border-radius:4px}
  .os .arrow{opacity:0;color:var(--royal);font-weight:700;font-size:18px;transition:opacity .2s ease, transform .2s ease}
  .os:hover .arrow{opacity:.5}

  /* Active story */
  .os.os-active{background:linear-gradient(135deg,#F4FAFF 0%, #EAF5FF 100%);box-shadow:0 14px 32px rgba(39,79,219,.14)}
  .os.os-active::before{opacity:1;width:5px}
  .os.os-active .label{color:var(--royal)}
  .os.os-active .arrow{opacity:1;transform:translateX(2px)}

  /* ---------- How we collect feedback (Live / Flex / Flow) ---------- */
  .collect{background:#fff;position:relative;overflow:hidden}
  .collect::before{content:"";position:absolute;top:-160px;right:-200px;width:520px;height:520px;border-radius:999px;background:radial-gradient(circle,rgba(9,212,200,.12),transparent 65%);pointer-events:none}
  .collect-head{max-width:1200px}
  .collect-head h2{font-size:44px;line-height:1.1;letter-spacing:-.015em;max-width:900px}
  .collect-head .lede{font-size:18px;line-height:1.55;margin-top:16px;max-width:1180px}
  .collect-grid{display:grid;grid-template-columns:1fr 2.1fr;gap:24px;align-items:stretch;margin-top:48px}

  .cc{background:#fff;border-radius:20px;padding:30px;box-shadow:var(--shadow-sm);display:flex;flex-direction:column;gap:16px;position:relative;overflow:hidden;height:100%}
  .cc-header{display:flex;align-items:center;justify-content:space-between;gap:10px;flex-wrap:wrap;row-gap:8px}
  .cc-tag{font-size:13px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--royal);display:inline-flex;align-items:center;gap:8px;white-space:nowrap}
  .cc-tag .sq{width:10px;height:10px;border-radius:3px}
  .cc-tag .beta-chip{display:inline-flex;align-items:center;height:20px;padding:0 9px;border-radius:999px;background:linear-gradient(135deg,#09D4C8,#14A6F8);color:#0B1220;font-size:10px;font-weight:800;letter-spacing:.14em;text-transform:uppercase;margin-left:4px;box-shadow:0 2px 6px rgba(9,212,200,.35)}
  .cc-kind{font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;padding:4px 10px;border-radius:999px;white-space:nowrap}
  .cc-kind-live{background:rgba(9,212,200,.2);color:#0A7A72}
  .cc-kind-ai{background:linear-gradient(135deg,rgba(39,79,219,.14),rgba(9,212,200,.22));color:var(--royal);display:inline-flex;align-items:center;gap:6px}
  .cc-kind-ai .spark{font-size:10px}
  .cc h3{font-size:21px;letter-spacing:-.02em;line-height:1.2;margin:0}
  .cc p{font-size:14.5px;color:var(--body);line-height:1.5;margin:0}
  .cc-meta{list-style:none;padding:0;margin:auto 0 0;display:flex;flex-direction:column;gap:7px;padding-top:10px;border-top:0}
  .cc-meta li{font-size:12.5px;color:var(--body);padding-left:18px;position:relative;line-height:1.4}
  .cc-meta li::before{content:"";position:absolute;left:0;top:7px;width:6px;height:6px;border-radius:999px;background:var(--teal)}

  /* Video-style viz panels for all three interview types */
  .cc-viz{border-radius:14px;padding:14px;min-height:220px;position:relative;overflow:hidden;background:#0C162E;display:flex;flex-direction:column;gap:12px}
  .cc-viz::before{content:"";position:absolute;inset:0;background:radial-gradient(circle at 20% 0%, rgba(20,166,248,.22), transparent 55%), radial-gradient(circle at 100% 100%, rgba(9,212,200,.16), transparent 55%);pointer-events:none}
  .cc-viz>*{position:relative;z-index:1}

  /* Top bar (above video tiles) */
  .vbar{display:flex;align-items:center;gap:8px;font-size:10px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:rgba(255,255,255,.82)}
  .vbar .rec{display:inline-flex;align-items:center;gap:6px;color:#FF6B6B}
  .vbar .rec .rdot{width:7px;height:7px;border-radius:999px;background:#FF6B6B;box-shadow:0 0 0 0 rgba(255,107,107,.6);animation:pulse 1.6s infinite}
  .vbar .live{display:inline-flex;align-items:center;gap:6px;color:#09D4C8}
  .vbar .live .ldot{width:7px;height:7px;border-radius:999px;background:#09D4C8;animation:pulse 1.6s infinite}
  .vbar .time{margin-left:auto;font-family:"SFMono-Regular","Monaco",monospace;color:rgba(255,255,255,.65);letter-spacing:.04em}
  .vbar .chip{display:inline-flex;align-items:center;gap:6px;padding:3px 8px;border-radius:999px;background:rgba(255,255,255,.12);color:rgba(255,255,255,.9);font-weight:700;letter-spacing:.08em}

  /* Video tiles grid */
  .vtiles{display:grid;grid-template-columns:1fr 1fr;gap:8px}
  .vtile{aspect-ratio:4/3;border-radius:10px;position:relative;overflow:hidden}
  .vtile.tall{aspect-ratio:1/1.05}
  .vtile .person{position:absolute;inset:0}
  .vtile .person.p1{background:radial-gradient(circle at 50% 36%, #F4C6A3 0%, #F4C6A3 18%, transparent 20%), linear-gradient(180deg,#3A78C8 0%, #2E58A6 100%)}
  .vtile .person.p2{background:radial-gradient(circle at 50% 36%, #EBB897 0%, #EBB897 18%, transparent 20%), linear-gradient(180deg,#5B52A8 0%, #3E3C78 100%)}
  .vtile .person.p3{background:radial-gradient(circle at 50% 36%, #D9A78A 0%, #D9A78A 18%, transparent 20%), linear-gradient(180deg,#1E5F8F 0%, #124166 100%)}
  .vtile .person.p4{background:radial-gradient(circle at 50% 36%, #E6BEA0 0%, #E6BEA0 18%, transparent 20%), linear-gradient(180deg,#4A8BA8 0%, #2B6986 100%)}
  .vtile .person::after{content:"";position:absolute;left:30%;right:30%;top:52%;bottom:0;background:inherit;background-size:cover;border-radius:100% 100% 0 0 / 50% 50% 0 0;filter:brightness(.9)}
  .vtile .lbl{position:absolute;bottom:6px;left:6px;padding:3px 7px;border-radius:6px;background:rgba(0,0,0,.5);color:#fff;font-size:10px;font-weight:600;letter-spacing:.02em;backdrop-filter:blur(4px)}
  .vtile .mic{position:absolute;bottom:6px;right:6px;width:20px;height:20px;border-radius:999px;background:rgba(9,212,200,.9);display:flex;align-items:center;justify-content:center;color:#052626;font-size:10px;font-weight:700}
  .vtile.active-speaker{box-shadow:0 0 0 2px #09D4C8}
  .vtile .corner-chip{position:absolute;top:6px;right:6px;padding:2px 7px;border-radius:999px;background:rgba(255,255,255,.18);color:#fff;font-size:9px;font-weight:700;letter-spacing:.08em}

  /* AI Agent avatar tile (not a person — a glowing orb) */
  .vtile.ai-tile{background:radial-gradient(circle at 50% 50%, rgba(20,166,248,.9) 0%, rgba(39,79,219,.7) 40%, rgba(14,22,46,1) 90%)}
  .vtile.ai-tile .orb{position:absolute;inset:0;display:flex;align-items:center;justify-content:center}
  .vtile.ai-tile .orb svg{width:60%;height:auto;filter:drop-shadow(0 0 14px rgba(9,212,200,.6))}
  .vtile.ai-tile .pulse-ring{position:absolute;left:50%;top:50%;width:70%;height:70%;border-radius:999px;border:1px solid rgba(9,212,200,.55);transform:translate(-50%,-50%);animation:ring 2.6s ease-out infinite}
  .vtile.ai-tile .pulse-ring.r2{animation-delay:.9s}

  @keyframes ring{0%{transform:translate(-50%,-50%) scale(.6);opacity:.9}100%{transform:translate(-50%,-50%) scale(1.35);opacity:0}}
  @keyframes pulse{0%,100%{opacity:1}50%{opacity:.35}}

  /* Transcript strip below tiles */
  .vstrip{padding:8px 10px;background:rgba(255,255,255,.08);border-radius:10px;color:rgba(255,255,255,.95);font-size:12px;line-height:1.4;backdrop-filter:blur(4px);display:flex;gap:8px;align-items:flex-start}
  .vstrip .who{font-size:9px;font-weight:800;letter-spacing:.12em;text-transform:uppercase;color:#09D4C8;flex-shrink:0;padding-top:1px;min-width:34px}
  .vstrip .who.human{color:#9DC6FF}
  .vstrip .txt{color:rgba(255,255,255,.92);font-size:11.5px;line-height:1.4;flex:1}

  /* Flex-specific: single large video with answer thumbnail below (Q→A→AI) */
  .vplayer{position:relative;aspect-ratio:16/10;border-radius:10px;overflow:hidden;background:#0F1A33}
  .vplayer .person{position:absolute;inset:0}
  .vplayer .play{position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);width:42px;height:42px;border-radius:999px;background:rgba(255,255,255,.9);display:flex;align-items:center;justify-content:center;color:#0F1A33;font-size:14px;box-shadow:0 6px 18px rgba(0,0,0,.35)}
  .vplayer .q-caption{position:absolute;bottom:0;left:0;right:0;padding:10px 12px 10px;background:linear-gradient(180deg,transparent 0%, rgba(0,0,0,.8) 100%);color:#fff;font-size:11.5px;line-height:1.35}
  .vplayer .q-caption .qnum{display:inline-block;font-size:9px;font-weight:800;color:#09D4C8;letter-spacing:.12em;text-transform:uppercase;margin-right:6px}
  .vplayer .pip{position:absolute;bottom:8px;right:8px;width:64px;aspect-ratio:4/3;border-radius:7px;overflow:hidden;box-shadow:0 4px 12px rgba(0,0,0,.5);border:2px solid rgba(255,255,255,.4)}
  .vplayer .pip .person{background:radial-gradient(circle at 50% 36%, #E6BEA0 0%, #E6BEA0 22%, transparent 24%), linear-gradient(180deg,#4A8BA8 0%, #2B6986 100%)}
  .vplayer .pip::after{content:"YOU";position:absolute;top:2px;left:4px;color:#fff;font-size:8px;font-weight:700;letter-spacing:.1em;text-shadow:0 1px 2px rgba(0,0,0,.6)}

  /* AI listening indicator for Flex */
  .ai-listen{display:flex;align-items:center;gap:10px;padding:8px 12px;background:linear-gradient(135deg,rgba(39,79,219,.35),rgba(9,212,200,.3));border-radius:10px;color:#fff;font-size:11px;font-weight:600}
  .ai-listen .chip-ai{display:inline-flex;align-items:center;justify-content:center;width:22px;height:22px;border-radius:7px;background:linear-gradient(135deg,#14A6F8,#09D4C8);color:#052626;font-weight:800;font-size:10px;letter-spacing:.06em}
  .ai-listen .wave{display:flex;align-items:center;gap:2px;margin-left:auto;height:14px}
  .ai-listen .wave span{width:2px;border-radius:2px;background:#09D4C8;animation:waveb 1s ease-in-out infinite}
  .ai-listen .wave span:nth-child(1){height:30%;animation-delay:0s}
  .ai-listen .wave span:nth-child(2){height:70%;animation-delay:.1s}
  .ai-listen .wave span:nth-child(3){height:50%;animation-delay:.2s}
  .ai-listen .wave span:nth-child(4){height:90%;animation-delay:.3s}
  .ai-listen .wave span:nth-child(5){height:40%;animation-delay:.4s}
  .ai-listen .wave span:nth-child(6){height:70%;animation-delay:.5s}
  @keyframes waveb{0%,100%{transform:scaleY(.6)}50%{transform:scaleY(1)}}

  /* AI group — wraps Flex + Flow */
  .ai-group{position:relative;border-radius:26px;padding:80px 24px 24px;
    background:
      radial-gradient(circle at 0% 0%, rgba(9,212,200,.16), transparent 55%),
      radial-gradient(circle at 100% 100%, rgba(39,79,219,.14), transparent 55%),
      linear-gradient(135deg,#F2F7FF 0%, #E9F3FE 100%);
  }
  .ai-label{position:absolute;top:22px;left:50%;transform:translateX(-50%);display:inline-flex;align-items:center;gap:12px;padding:12px 22px 12px 14px;border-radius:999px;background:#fff;color:var(--royal);font-size:13px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;box-shadow:0 10px 24px rgba(39,79,219,.16);white-space:nowrap}
  .ai-label .spark-box{display:inline-flex;align-items:center;justify-content:center;width:28px;height:28px;border-radius:10px;background:linear-gradient(135deg,#274FDB,#09D4C8);color:#fff;font-size:14px;font-weight:700;box-shadow:0 4px 10px rgba(9,212,200,.35)}
  .ai-pair{display:grid;grid-template-columns:1fr 1fr;gap:18px;height:100%}

  /* ---------- Customer journey (6 moments, vertical timeline) ---------- */
  .journey{background:#fff;position:relative;overflow:hidden;padding:120px 0 80px}
  .journey::before{content:"";position:absolute;top:-120px;left:-180px;width:520px;height:520px;border-radius:999px;background:radial-gradient(circle,rgba(9,212,200,.1),transparent 65%);pointer-events:none}
  .journey::after{content:"";position:absolute;bottom:-120px;right:-180px;width:520px;height:520px;border-radius:999px;background:radial-gradient(circle,rgba(39,79,219,.1),transparent 65%);pointer-events:none}
  .journey-head{max-width:1200px;margin-bottom:16px;position:relative;z-index:1}
  .journey-head h2{font-size:48px;line-height:1.08;letter-spacing:-.015em;max-width:960px}
  .journey-head .lede{font-size:18px;line-height:1.55;margin-top:16px;max-width:1180px}
  .journey-head .lede .em{color:var(--royal);font-weight:600}

  /* Per-moment color themes (shared by tabs + panels) */
  .m-market{--grad-a:#09D4C8;--grad-b:#14A6F8}
  .m-buying{--grad-a:#14A6F8;--grad-b:#274FDB}
  .m-implementation{--grad-a:#00B56B;--grad-b:#00D4A8}
  .m-product-dec{--grad-a:#274FDB;--grad-b:#1A2FA0}
  .m-adoption{--grad-a:#7A4BFF;--grad-b:#B88AFF}
  .m-renewal{--grad-a:#F4B81A;--grad-b:#F59E0B}

  /* Horizontal timeline tabs */
  .journey-rail{position:relative;max-width:1200px;margin:56px auto 0;padding:0 24px}
  .journey-tabs{display:grid;grid-template-columns:repeat(6,1fr);gap:8px;position:relative;padding-top:64px}
  .journey-tabs::before{content:"";position:absolute;top:24px;left:8%;right:8%;height:3px;background:linear-gradient(90deg,#09D4C8 0%,#14A6F8 18%,#00B56B 38%,#274FDB 58%,#7A4BFF 78%,#F4B81A 100%);border-radius:999px;opacity:.5}
  .jt{position:relative;display:flex;flex-direction:column;align-items:center;gap:10px;background:none;border:0;cursor:pointer;padding:0 4px;color:var(--body);text-align:center;font-family:inherit;transition:transform .18s ease}
  .jt:hover{transform:translateY(-1px)}
  .jt .jt-num{position:absolute;top:-54px;left:50%;transform:translateX(-50%);width:42px;height:42px;border-radius:999px;display:flex;align-items:center;justify-content:center;font-size:12.5px;font-weight:700;letter-spacing:.04em;color:var(--royal);background:#fff;box-shadow:0 0 0 4px #fff, 0 8px 18px rgba(39,79,219,.14);z-index:3;transition:all .2s ease}
  .jt .jt-label{font-size:12.5px;font-weight:600;letter-spacing:.02em;color:var(--body);opacity:.65;line-height:1.3;margin-top:4px}
  .jt.active .jt-num{color:#fff;width:52px;height:52px;top:-58px;font-size:14px;background:linear-gradient(135deg,var(--grad-a,#274FDB),var(--grad-b,#09D4C8));box-shadow:0 0 0 4px #fff, 0 14px 28px rgba(39,79,219,.3)}
  .jt.active .jt-label{color:var(--ink);opacity:1;font-weight:700}

  /* Expandable panel */
  .journey-panels{position:relative;max-width:1200px;margin:48px auto 0;padding:0 24px}
  .jp{display:none;grid-template-columns:1.1fr 1fr;gap:48px;align-items:stretch;background:#fff;border-radius:24px;box-shadow:0 24px 60px rgba(20,40,90,.09), 0 6px 14px rgba(20,40,90,.04);padding:48px 48px;position:relative;overflow:hidden}
  .jp::before{content:"";position:absolute;top:0;left:0;right:0;height:4px;background:linear-gradient(90deg,var(--grad-a,#274FDB),var(--grad-b,#09D4C8))}
  .jp.active{display:grid;animation:jpIn .35s ease}
  @keyframes jpIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}
  .jp-text{display:flex;flex-direction:column;gap:14px;justify-content:center}
  .jp-icon{width:60px;height:60px;border-radius:16px;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,var(--grad-a,#274FDB),var(--grad-b,#09D4C8));box-shadow:0 10px 22px rgba(39,79,219,.22)}
  .jp-icon img{width:34px;height:34px;filter:brightness(0) invert(1);opacity:.95}
  .jp-eyebrow{font-size:12.5px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--grad-a,#274FDB);margin-top:2px}
  .jp h3{font-size:30px;line-height:1.16;letter-spacing:-.02em;margin:0;color:var(--ink);font-weight:600}
  .jp-text p{font-size:15.5px;color:var(--body);line-height:1.55;margin:0}
  .jp-link{margin-top:6px;font-size:14px;font-weight:600;color:var(--grad-a,#274FDB);display:inline-flex;align-items:center;gap:6px;text-decoration:none}
  .jp-link .arrow{transition:transform .2s}
  .jp-link:hover .arrow{transform:translateX(3px)}
  .jp.m-renewal .jp-eyebrow, .jp.m-renewal .jp-link{color:#B78814}
  .jp.m-implementation .jp-eyebrow, .jp.m-implementation .jp-link{color:#009B5E}

  /* Visual side — product logo variant */
  .jp-visual{border-radius:20px;background:linear-gradient(160deg,rgba(39,79,219,.04),rgba(9,212,200,.07));padding:36px 32px;display:flex;flex-direction:column;justify-content:center;align-items:flex-start;gap:18px;position:relative;overflow:hidden;min-height:300px}
  .jp-visual::after{content:"";position:absolute;right:-70px;bottom:-70px;width:260px;height:260px;border-radius:999px;background:radial-gradient(circle,rgba(39,79,219,.08),transparent 70%);pointer-events:none}
  .jp.m-market .jp-visual::after{background:radial-gradient(circle,rgba(9,212,200,.14),transparent 70%)}
  .jp.m-implementation .jp-visual::after{background:radial-gradient(circle,rgba(0,181,107,.12),transparent 70%)}
  .jp.m-adoption .jp-visual::after{background:radial-gradient(circle,rgba(122,75,255,.12),transparent 70%)}
  .jp.m-renewal .jp-visual::after{background:radial-gradient(circle,rgba(244,184,26,.14),transparent 70%)}
  .jp-product-tag, .cc-badge{font-size:10.5px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--grad-a,#274FDB);padding:6px 12px;border-radius:999px;background:#fff;box-shadow:0 4px 10px rgba(39,79,219,.08);position:relative;z-index:1}
  .jp-product-wordmark{display:flex;align-items:center;gap:16px;position:relative;z-index:1}
  .jp-product-logo{width:86px;height:86px;object-fit:contain;flex:0 0 86px;filter:drop-shadow(0 8px 18px rgba(20,40,90,.12))}
  .jp-product-name{display:flex;flex-direction:column;gap:2px}
  .jp-product-name .jp-pn-lockup{font-size:13px;font-weight:600;color:var(--body);letter-spacing:.02em;text-transform:uppercase;opacity:.7;line-height:1}
  .jp-product-name .jp-pn-title{font-size:22px;font-weight:700;color:var(--ink);letter-spacing:-.015em;line-height:1.1}
  .jp-product-sub, .cc-sub{font-size:13.5px;color:var(--body);line-height:1.5;margin:0;max-width:380px;position:relative;z-index:1}

  /* Visual side — cross-cutting variant */
  .cc-icon{width:72px;height:72px;border-radius:18px;background:linear-gradient(135deg,var(--grad-a,#274FDB),var(--grad-b,#09D4C8));display:flex;align-items:center;justify-content:center;box-shadow:0 12px 24px rgba(39,79,219,.22);position:relative;z-index:1}
  .cc-icon img{width:40px;height:40px;filter:brightness(0) invert(1)}
  .cc-label{font-size:17px;font-weight:700;color:var(--ink);letter-spacing:-.01em;position:relative;z-index:1}

  /* ---------- Social proof strip ---------- */
  .proof{margin-top:96px;position:relative;z-index:1}
  .proof-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:20px;max-width:1140px;margin:0 auto}
  .proof-card{background:#fff;border-radius:20px;padding:30px 28px;box-shadow:var(--shadow-sm);display:flex;flex-direction:column;gap:10px;position:relative;overflow:hidden}
  .proof-card::before{content:"";position:absolute;top:-40px;right:-40px;width:120px;height:120px;border-radius:999px;background:radial-gradient(circle,rgba(9,212,200,.14),transparent 70%)}
  .proof-card>*{position:relative;z-index:1}
  .proof-card .big{font-size:44px;font-weight:600;color:var(--royal);letter-spacing:-.025em;line-height:1}
  .proof-card .big .plus{font-size:28px;color:var(--teal);margin-left:2px}
  .proof-card .lbl{font-size:13.5px;color:var(--body);line-height:1.4}
  .proof-card .stars{display:inline-flex;gap:2px;color:#F4B81A;font-size:14px;letter-spacing:.05em;line-height:1}
  .proof-card .tag{display:inline-flex;align-items:center;gap:6px;padding:4px 10px;border-radius:999px;background:rgba(39,79,219,.08);color:var(--royal);font-size:11px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;align-self:flex-start}

  /* ---------- Engine (3-step how it works) ---------- */
  .engine{background:var(--page)}
  .engine-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
  .step{background:#fff;border-radius:20px;padding:36px;box-shadow:var(--shadow-sm);display:flex;flex-direction:column;gap:18px;position:relative}
  .step .num{display:inline-flex;align-items:center;justify-content:center;width:36px;height:36px;border-radius:999px;background:linear-gradient(135deg,var(--royal),var(--blue));color:#fff;font-weight:600;font-size:14px}
  .step h3{font-size:22px}
  .step img{height:64px;width:auto;object-fit:contain}
  .step ul{list-style:none;padding:0;margin-top:8px}
  .step li{font-size:15px;color:var(--body);padding-left:22px;position:relative;margin-top:8px;line-height:1.45}
  .step li::before{content:"";position:absolute;left:0;top:9px;width:7px;height:7px;border-radius:999px;background:var(--teal)}

  /* ---------- Product suite ---------- */
  .products{background:#fff}
  .prod-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:24px}
  .prod{border-radius:20px;padding:40px;color:#fff;position:relative;overflow:hidden;min-height:260px;display:flex;flex-direction:column;justify-content:space-between;box-shadow:var(--shadow-sm)}
  .prod .eyebrow{color:rgba(255,255,255,.85)}
  .prod h3{color:#fff;font-size:26px;max-width:420px}
  .prod p{color:rgba(255,255,255,.88);font-size:15px;max-width:420px;margin-top:12px}
  .prod .prod-icon{position:absolute;right:20px;top:20px;width:88px;height:88px}
  .prod .prod-link{display:inline-flex;align-items:center;gap:8px;margin-top:22px;color:#fff;font-weight:600;font-size:15px;padding:10px 18px;background:rgba(255,255,255,.18);border-radius:999px;align-self:flex-start}
  .prod .prod-link:hover{background:rgba(255,255,255,.28)}
  .prod.wl{background:linear-gradient(135deg,#14A6F8 0%, #09D4C8 100%)}
  .prod.ret{background:linear-gradient(135deg,#F4B81A 0%, #F59E0B 100%)}
  .prod.impl{background:linear-gradient(135deg,#00B56B 0%, #00D4A8 100%)}
  .prod.cx{background:linear-gradient(135deg,#7A4BFF 0%, #B88AFF 100%)}

  /* ---------- Outcomes (stats + featured quote) ---------- */
  /* Standalone social proof section */
  .proof-section{background:#fff;padding:110px 0 120px;position:relative;overflow:hidden}
  .proof-section::before{content:"";position:absolute;top:-160px;left:50%;transform:translateX(-50%);width:720px;height:720px;border-radius:999px;background:radial-gradient(circle,rgba(39,79,219,.05),transparent 65%);pointer-events:none}
  .proof-section .section-head{position:relative;z-index:1}
  .proof-section .proof-grid{position:relative;z-index:1}

  .outcomes{background:var(--page);position:relative;overflow:hidden}
  .outcomes .grid{display:grid;grid-template-columns:1fr 1.3fr;gap:40px}
  .stat-stack{display:flex;flex-direction:column;gap:20px}
  .stat-big{background:#fff;border-radius:20px;padding:32px;box-shadow:var(--shadow-sm);display:flex;align-items:center;gap:22px}
  .stat-big .ringnum{font-size:44px;font-weight:600;color:var(--royal);letter-spacing:-.02em;min-width:110px}
  .stat-big .ringnum .accent{color:var(--teal)}
  .stat-big p{font-size:15px;color:var(--body);margin:0}
  .stat-big h4{font-size:17px;font-weight:600;color:var(--ink);margin-bottom:4px}
  .quote-card{background:#fff;border-radius:20px;padding:48px;box-shadow:var(--shadow-sm);display:flex;flex-direction:column;justify-content:space-between;position:relative;overflow:hidden}
  .quote-card::before{content:"";position:absolute;top:-30px;right:-30px;width:180px;height:180px;border-radius:999px;background:radial-gradient(circle, rgba(9,212,200,.18), transparent 70%)}
  .quote-card .qmark{font-family:'Inter',sans-serif;font-weight:600;color:var(--teal);font-size:17px}
  .quote-card blockquote{font-size:24px;line-height:1.35;color:var(--ink);font-weight:500;margin-top:18px;max-width:520px}
  .quote-card .attr{display:flex;align-items:center;gap:14px;margin-top:28px}
  .quote-card .avatar{width:52px;height:52px;border-radius:999px;background:linear-gradient(135deg,#274FDB,#09D4C8);display:flex;align-items:center;justify-content:center;color:#fff;font-weight:600}
  .quote-card .who .name{font-weight:600;color:var(--ink);font-size:15px}
  .quote-card .who .role{font-size:14px;color:var(--body);margin-top:2px}

  /* ---------- Personas ---------- */
  .personas{position:relative;color:#fff;overflow:hidden;padding:120px 0;isolation:isolate;
    background:
      radial-gradient(circle at 100% 0%, rgba(9,212,200,.45), transparent 50%),
      radial-gradient(circle at 0% 100%, rgba(39,79,219,.55), transparent 55%),
      linear-gradient(120deg,#274FDB 0%, #14A6F8 50%, #09D4C8 100%);
  }
  .personas h2{color:#fff}
  .personas .lede{color:rgba(255,255,255,.88)}

  /* Persona video reel */
  .reel{display:grid;grid-template-columns:repeat(4,1fr);gap:20px;margin-top:56px;position:relative;z-index:1}
  .vclip{position:relative;border-radius:22px;overflow:hidden;aspect-ratio:9/14;background:#0F2FB3;box-shadow:0 24px 50px rgba(0,20,60,.32);cursor:pointer;isolation:isolate;transition:transform .22s ease, box-shadow .22s ease}
  .vclip:hover{transform:translateY(-3px);box-shadow:0 30px 60px rgba(0,20,60,.42)}
  /* Blue gradient backdrop per role (subtle variation within blue family) */
  .vclip.cro,.vbox-video.cro{background:linear-gradient(180deg,#274FDB 0%, #1E3FB8 45%, #14A6F8 100%)}
  .vclip.cmo,.vbox-video.cmo{background:linear-gradient(180deg,#1A3FB5 0%, #2966D6 50%, #4BB0E8 100%)}
  .vclip.cs,.vbox-video.cs{background:linear-gradient(180deg,#15378F 0%, #1F58C8 50%, #09D4C8 100%)}
  .vclip.pmm,.vbox-video.pmm{background:linear-gradient(180deg,#2A4AD0 0%, #3A6EE0 50%, #5FC0F8 100%)}
  /* B&W portrait placeholder — sits in the upper portion, leaving room for footer */
  .vclip .vposter{position:absolute;left:0;right:0;top:0;bottom:90px;z-index:0;display:flex;align-items:flex-end;justify-content:center;overflow:hidden}
  .vclip .vportrait{width:88%;max-width:240px;height:98%;filter:grayscale(1) contrast(1.06) brightness(1.04);opacity:.95}
  /* Play button: small square with white triangle, centered on the portrait */
  .vclip .vplay{position:absolute;left:50%;top:calc(50% - 45px);transform:translate(-50%,-50%);width:46px;height:46px;border-radius:10px;background:rgba(255,255,255,.98);color:var(--royal);display:flex;align-items:center;justify-content:center;box-shadow:0 10px 26px rgba(5,15,50,.45);transition:transform .2s ease;z-index:3}
  .vclip .vplay svg{width:16px;height:16px;margin-left:2px}
  .vclip:hover .vplay{transform:translate(-50%,-50%) scale(1.06)}
  /* Bottom white footer "card" — name/role on left, company wordmark on right */
